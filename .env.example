# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=orgagent
POSTGRES_USER=orgagent
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://orgagent:changeme@postgres:5432/orgagent

# ─── Keycloak ────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=org-agent
KEYCLOAK_CLIENT_ID=org-agent-backend
KEYCLOAK_CLIENT_SECRET=changeme
KEYCLOAK_AUDIENCE=org-agent-backend

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5

# ─── pgvector / RAG (Phase 2) ────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
RAG_TOP_K=8
RAG_HYBRID_ALPHA=0.75

# ─── Jira (Phase 3) ──────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_SERVICE_ACCOUNT_EMAIL=agent@yourorg.com
JIRA_API_TOKEN=changeme
JIRA_CACHE_TTL_SECONDS=60

# ─── Read-only DB (Phase 3) ──────────────────────────────────────────────────
READONLY_DB_URL=postgresql+asyncpg://agent_readonly:changeme@postgres:5432/orgagent
WHITELISTED_TABLES=users,projects,tickets,departments

# ─── Redis (Phase 5) ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=false

# ─── Frontend (set in docker-compose or nginx) ───────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=org-agent
VITE_KEYCLOAK_CLIENT_ID=org-agent-frontend
