# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by Docker Compose to initialise the database container
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=orgagent
POSTGRES_USER=orgagent
POSTGRES_PASSWORD=changeme                           # CHANGE IN PRODUCTION

# Full async connection strings used by the application
DATABASE_URL=postgresql+asyncpg://orgagent:changeme@postgres:5432/orgagent
READONLY_DB_URL=postgresql+asyncpg://agent_readonly:changeme@postgres:5432/orgagent

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=org-agent
KEYCLOAK_CLIENT_ID=org-agent-backend
KEYCLOAK_CLIENT_SECRET=changeme                      # CHANGE IN PRODUCTION
KEYCLOAK_AUDIENCE=org-agent-backend

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Controls which LLM the agent uses.
# Accepted values: "anthropic" | "openai" | "gemini"
LLM_PROVIDER=anthropic

# Anthropic — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5

# OpenAI LLM — required when LLM_PROVIDER=openai
# Note: this is the key used for the chat model only.
#       For embeddings, set OPENAI_API_KEY in the RAG section below.
#       Both can share the same key if you use one OpenAI account.
OPENAI_LLM_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                                  # e.g. gpt-4o, gpt-4o-mini, gpt-4-turbo

# Google Gemini — required when LLM_PROVIDER=gemini
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro                          # e.g. gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash

# ─── RAG / Embeddings (Phase 2) ───────────────────────────────────────────────
# Embedding model used to vectorise document chunks and queries.
# Currently only "openai" is supported (text-embedding-3-small, 1536 dims).
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...                                # can be the same key as OPENAI_LLM_API_KEY

# Number of chunks returned per hybrid search
RAG_TOP_K=8

# Score fusion weight: 1.0 = pure semantic, 0.0 = pure keyword (BM25/FTS)
RAG_HYBRID_ALPHA=0.75

# ─── Agent DB Access (Phase 3) ────────────────────────────────────────────────
# Comma-separated list of tables the agent is allowed to query
WHITELISTED_TABLES=users,projects,tickets,departments

# ─── Jira (Phase 3) ───────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_SERVICE_ACCOUNT_EMAIL=agent@yourorg.com
JIRA_API_TOKEN=changeme
JIRA_CACHE_TTL_SECONDS=60

# ─── Redis / Cache (Phase 5) ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=false

# ─── Frontend (Vite / Docker Compose) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=org-agent
VITE_KEYCLOAK_CLIENT_ID=org-agent-frontend
